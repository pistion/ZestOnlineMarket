# Runtime mode
# APP_ENV: local | staging | production
APP_ENV=local
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_DEMO_STALLS=true
JSON_LIMIT=12mb
CSRF_ENABLED=true
CSRF_HEADER_NAME=x-csrf-token
REQUEST_LOGGING_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_LOGIN=8
AUTH_RATE_LIMIT_MAX_REGISTER=4
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=40
SELLER_WRITE_RATE_LIMIT_WINDOW_MS=60000
SELLER_WRITE_RATE_LIMIT_MAX=60
ORDER_RATE_LIMIT_WINDOW_MS=900000
ORDER_RATE_LIMIT_MAX=6
REPORT_RATE_LIMIT_WINDOW_MS=900000
REPORT_RATE_LIMIT_MAX=6
# Live runtime is PostgreSQL-only.
DB_PROVIDER=postgres
DATABASE_URL=
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=zestonlinemarket
PGUSER=postgres
PGPASSWORD=replace-with-your-local-postgres-password
# Ops-only legacy snapshot location
LEGACY_SQLITE_PATH=reference/sqlite/users.db
