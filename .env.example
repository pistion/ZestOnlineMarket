# Runtime mode
# APP_ENV: local | staging | production
APP_ENV=local
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_DEMO_STALLS=true
FEATURE_SEARCH=true
FEATURE_REVIEWS=true
FEATURE_DISCOUNTS=true
FEATURE_ADMIN=true
JSON_LIMIT=12mb
CSRF_ENABLED=true
CSRF_HEADER_NAME=x-csrf-token
REQUEST_LOGGING_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_LOGIN=8
AUTH_RATE_LIMIT_MAX_REGISTER=4
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=40
SELLER_WRITE_RATE_LIMIT_WINDOW_MS=60000
SELLER_WRITE_RATE_LIMIT_MAX=60
ORDER_RATE_LIMIT_WINDOW_MS=900000
ORDER_RATE_LIMIT_MAX=4
REPORT_RATE_LIMIT_WINDOW_MS=900000
REPORT_RATE_LIMIT_MAX=6
# Live runtime is PostgreSQL-only.
DB_PROVIDER=postgres
# DATABASE_URL is preferred for production/remote (e.g. Render).
# Format: postgresql://user:password@host:port/database
DATABASE_URL=
DB_RUN_MIGRATIONS_ON_STARTUP=true
DB_CONNECT_RETRIES=6
DB_CONNECT_RETRY_DELAY_MS=2000
DB_SSL=
DB_SSL_MODE=
DB_SSL_REJECT_UNAUTHORIZED=false
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=zest_online_market
PGUSER=postgres
PGPASSWORD=replace-with-your-local-postgres-password
DB_POOL_MIN=0
DB_POOL_MAX=10
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_BASE_URL=
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Zest Market <no-reply@zest.local>
# Ops-only legacy snapshot location
LEGACY_SQLITE_PATH=reference/sqlite/users.db
