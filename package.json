{
  "name": "zest-online-market",
  "version": "1.0.0",
  "private": true,
  "description": "Live runtime for Zest Online Market",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "local:checkpoint": "node ops/local/checkpoint.js",
    "local:history": "node ops/local/history.js",
    "check:js": "node ops/tests/check-js.js",
    "check:repo": "node ops/tests/repo-guard.js",
    "check:size": "node ops/tests/size-guard.js",
    "test:unit": "vitest run --configLoader native --pool threads tests/unit",
    "test:integration": "node ops/tests/test-integration.js",
    "test": "npm run test:unit && npm run test:integration",
    "smoke": "node ops/smoke/smoke.js",
    "db:migrate": "node ops/db/migrate.js",
    "db:rollback": "node ops/db/rollback.js",
    "db:seed": "node ops/db/seed.js",
    "db:snapshot": "node ops/db/snapshot.js",
    "db:etl:identity-store": "node ops/db/etl-identity-store.js",
    "db:etl:catalog": "node ops/db/etl-catalog.js",
    "db:verify": "node ops/db/verify.js",
    "db:buyer": "node ops/db/buyer-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "ejs": "^3.1.10",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.0",
    "pg": "^8.12.0",
    "sqlite3": "^5.1.7",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
