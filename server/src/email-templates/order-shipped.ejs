<div style="font-family: Inter, Arial, sans-serif; color: #0f172a; line-height: 1.6;">
  <p style="font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: #2563eb;">Zest Market</p>
  <h1 style="margin: 0 0 12px;"><%= statusLabel %></h1>
  <p>Hi <%= customerName || "there" %>,</p>
  <p>Your order <strong><%= orderNumber %></strong> is now marked as <strong><%= statusLabel.toLowerCase() %></strong>.</p>
  <% if (trackingNumber) { %>
  <p>Tracking number: <strong><%= trackingNumber %></strong></p>
  <% } %>
  <% if (carrier) { %>
  <p>Carrier: <strong><%= carrier %></strong></p>
  <% } %>
</div>
