<div class="auth-shell">
  <aside class="auth-aside">
    <div class="auth-aside__copy">
      <span class="auth-eyebrow">Zest Access</span>
      <h2>Secure entry, clearer recovery, and a stronger first impression.</h2>
      <p>
        Sign in with email, Google, or Facebook. New accounts confirm their password before
        they continue into the buyer or seller flow.
      </p>
    </div>

    <div class="auth-aside__highlights" aria-label="Access overview">
      <article class="auth-highlight">
        <strong>Buyer flow</strong>
        <span>/buyer/profile</span>
        <p>Profiles, feed, marketplace discovery, and checkout stay connected after sign-in.</p>
      </article>
      <article class="auth-highlight">
        <strong>Seller flow</strong>
        <span>/seller/wizard-setup</span>
        <p>New seller accounts bootstrap directly into the setup path with Postgres-backed state.</p>
      </article>
    </div>

    <div class="auth-chip-row">
      <span class="auth-chip">Password confirm</span>
      <span class="auth-chip">Request IDs</span>
      <span class="auth-chip">Troubleshooting hints</span>
      <span class="auth-chip">Social auth ready</span>
    </div>
  </aside>

  <section class="auth-panel">
    <div class="auth-brand">ZEST MARKET</div>

    <section class="auth-session" id="authSessionBanner" hidden>
      <div class="auth-session__copy">
        <span class="auth-eyebrow">Active session</span>
        <p>
          You are already signed in as <strong id="authSessionEmail">your account</strong>.
          Continue, switch account, or sign out first.
        </p>
        <div class="auth-session__timer" id="authSessionTimerRow" hidden>
          <span class="auth-session__timer-label">Session expires in</span>
          <strong id="authSessionTimer">--:--</strong>
        </div>
      </div>
      <div class="auth-session__actions">
        <a class="auth-btn auth-btn--primary" id="authSessionContinueLink" href="/auth/signin">Continue</a>
        <button class="auth-btn auth-btn--secondary" id="authSessionSwitchBtn" type="button">Switch account</button>
        <button class="auth-btn auth-btn--secondary" id="authSessionLogoutBtn" type="button">Sign out</button>
      </div>
    </section>

    <section class="auth-card" id="authCard">
      <header class="auth-card__header">
        <div>
          <p class="auth-card__kicker" id="authRoleLabel">Buyer Access</p>
          <h1 class="auth-card__title" id="authTitle">Welcome back</h1>
          <p class="auth-card__copy" id="authIntro">
            Sign in or create an account to continue into the correct buyer or seller flow.
          </p>
        </div>
      </header>

      <div class="auth-tabs" id="authRoleTabs" role="tablist" aria-label="Choose account type">
        <button class="auth-tab is-active" data-role="buyer" id="authTabBuyer" type="button" role="tab" aria-selected="true">
          <i class="fas fa-shopping-bag"></i>
          <span>Buyer</span>
        </button>
        <button class="auth-tab" data-role="seller" id="authTabSeller" type="button" role="tab" aria-selected="false">
          <i class="fas fa-store"></i>
          <span>Seller</span>
        </button>
      </div>

      <div class="auth-social">
        <a class="auth-social-btn auth-social-btn--google" id="authGoogleBtn" data-provider="google" href="/auth/oauth/google">
          <i class="fa-brands fa-google"></i>
          <span id="authGoogleCopy">Continue with Google</span>
        </a>
        <a class="auth-social-btn auth-social-btn--facebook" id="authFacebookBtn" data-provider="facebook" href="/auth/oauth/facebook">
          <i class="fa-brands fa-facebook-f"></i>
          <span id="authFacebookCopy">Continue with Facebook</span>
        </a>
      </div>

      <div class="auth-divider">
        <span id="authDividerCopy">or continue with email</span>
      </div>

      <form class="auth-form" id="authForm" novalidate>
        <label class="auth-field">
          <span>Email</span>
          <input id="authEmail" type="email" autocomplete="email" required placeholder="you@example.com" />
        </label>

        <label class="auth-field">
          <span>Password</span>
          <input id="authPassword" type="password" autocomplete="current-password" required placeholder="Enter your password" />
          <small class="auth-field__meta" id="authPasswordMeta">
            Use at least 8 characters with both letters and numbers.
          </small>
        </label>

        <label class="auth-field" id="authConfirmField" hidden>
          <span>Confirm password</span>
          <input id="authConfirmPassword" type="password" autocomplete="new-password" placeholder="Repeat your password" />
        </label>

        <div class="auth-password-rules" id="authPasswordRules">
          <span class="auth-rule">8-128 chars</span>
          <span class="auth-rule">Letters + numbers</span>
          <span class="auth-rule">Confirm before submit</span>
        </div>

        <button class="auth-btn auth-btn--primary auth-btn--block" id="authSubmitBtn" type="submit">
          <span id="authSubmitText">Sign in</span>
          <span class="auth-spinner" id="authSpinner" hidden aria-hidden="true"></span>
        </button>
      </form>

      <div class="auth-feedback">
        <p class="auth-error" id="authError" aria-live="polite" hidden></p>
        <p class="auth-notice" id="authNotice" aria-live="polite" hidden></p>
      </div>

      <section class="auth-troubleshoot" id="authSupportBox" hidden>
        <div class="auth-troubleshoot__header">
          <strong>Troubleshooting</strong>
          <span class="auth-support-request" id="authSupportRequestId" hidden></span>
        </div>
        <p class="auth-troubleshoot__hint" id="authSupportHint"></p>
        <ul class="auth-troubleshoot__list" id="authSupportTips"></ul>
      </section>

      <div class="auth-toggle">
        <span id="authToggleCopy">Need an account?</span>
        <a href="#" id="authModeToggle">Create one</a>
      </div>

      <div class="auth-helper" id="authHelper">
        Buyer sign-up opens buyer setup first. Seller sign-in resumes the seller workspace based on store completion.
      </div>
    </section>
  </section>
</div>
