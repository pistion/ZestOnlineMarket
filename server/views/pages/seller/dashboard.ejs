</aside>

<main class="main">
    <header class="main-header">
        <div>
            <p class="eyebrow">Seller workspace</p>
            <h1 id="page-title">Overview</h1>
            <p class="header-copy">Keep an eye on sales, inventory, support load, and store readiness from one place.</p>
        </div>
        <div class="header-actions">
            <div class="header-chip" id="sellerDashboardTemplateChip"><i class="fas fa-layer-group"></i> Products Store</div>
            <div class="header-chip" id="sellerDashboardVisibilityChip"><i class="fas fa-circle"></i> Draft storefront</div>
            <div class="header-chip" id="sellerDashboardSetupChip"><i class="fas fa-bolt"></i> Setup in progress</div>
        </div>
    </header>

    <section id="analytics" class="dashboard-section active">
        <article class="workspace-banner">
            <div class="workspace-banner__copy">
                <p class="eyebrow">Store lifecycle</p>
                <h2 id="sellerWorkspaceBannerTitle">Finish your storefront setup</h2>
                <p class="workspace-banner__text" id="sellerWorkspaceBannerCopy">
                    Complete your store details, review the template, and publish when the storefront is ready.
                </p>
                <div class="workspace-banner__pills">
                    <span class="workspace-pill" id="sellerWorkspaceTemplatePill">Physical products</span>
                    <span class="workspace-pill" id="sellerWorkspaceVisibilityPill">Draft storefront</span>
                    <span class="workspace-pill" id="sellerWorkspaceStepPill">Step 1 of 4</span>
                </div>
            </div>
            <div class="workspace-banner__actions">
                <a class="header-action-link header-action-link--primary" id="sellerDashboardPrimaryAction" href="/seller/store/settings">Continue setup</a>
                <a class="header-action-link" id="sellerDashboardTemplateAction" href="/seller/store/template">Change template</a>
                <a class="header-action-link" id="sellerDashboardPublicStoreLink" href="/stores/example" hidden>Open public store</a>
            </div>
        </article>

        <div class="cards-grid">
            <article class="card highlight">
                <div class="card-icon"><i class="fas fa-sack-dollar"></i></div>
                <h3>Revenue this month</h3>
                <p class="metric" id="sellerRevenueMetric">K0.00 <span class="trend positive" id="sellerRevenueTrend">Preview</span></p>
                <p class="card-copy" id="sellerRevenueCopy">Revenue now updates from real paid, shipped, delivered, and refunded orders.</p>
            </article>
            <article class="card highlight">
                <div class="card-icon"><i class="fas fa-bag-shopping"></i></div>
                <h3>Orders processed</h3>
                <p class="metric" id="sellerOrdersMetric">0 <span class="trend positive" id="sellerOrdersTrend">Waiting</span></p>
                <p class="card-copy" id="sellerOrdersCopy">Track new paid orders here, then open Store Orders to manage shipment and delivery.</p>
            </article>
            <article class="card highlight">
                <div class="card-icon"><i class="fas fa-headset"></i></div>
                <h3>Store updates</h3>
                <p class="metric" id="sellerUpdatesMetric">0 <span class="trend positive" id="sellerUpdatesTrend">Quiet</span></p>
                <p class="card-copy" id="sellerUpdatesCopy">Publish seller updates to keep followers aware of drops, promos, and announcements.</p>
            </article>
            <article class="card highlight">
                <div class="card-icon"><i class="fas fa-box-open"></i></div>
                <h3>Live listings</h3>
                <p class="metric" id="sellerProductsMetric">0 <span class="trend negative" id="sellerProductsTrend">Draft only</span></p>
                <p class="card-copy" id="sellerProductsCopy">Finish setup and publish listings to make this storefront visible across marketplace discovery.</p>
            </article>
        </div>

        <div class="split-grid">
            <div class="chart-container">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Readiness snapshot</p>
                        <h2>Store health overview</h2>
                    </div>
                    <p class="section-copy" id="sellerHealthCopy">Track your live readiness, publishing state, and storefront momentum from one place.</p>
                </div>
                <canvas id="salesChart"></canvas>
            </div>

            <div class="note-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Action queue</p>
                        <h2>Next best actions</h2>
                    </div>
                </div>
                <ul class="alerts-list" id="sellerActionQueue">
                    <li><i class="fas fa-store"></i> Complete your store setup so the storefront can be published.</li>
                    <li><i class="fas fa-layer-group"></i> Confirm the template that best fits the way you sell.</li>
                    <li><i class="fas fa-bullhorn"></i> Add listings and store updates so buyers have something to discover.</li>
                </ul>
            </div>
        </div>
    </section>

    <section id="sales" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Sales performance</p>
                    <h2>Sales trends</h2>
                </div>
                <p class="section-copy">Keep a clean monthly view of revenue, order volume, and momentum.</p>
            </div>
            <div class="chart-container compact">
                <canvas id="trendsChart"></canvas>
            </div>
            <table class="data-table">
                <thead>
                    <tr><th>Month</th><th>Sales</th><th>Orders</th><th>Growth</th></tr>
                </thead>
                <tbody>
                    <tr><td>Jan 2024</td><td>K20,000</td><td>100</td><td>+5%</td></tr>
                    <tr><td>Feb 2024</td><td>K22,500</td><td>110</td><td>+12%</td></tr>
                    <tr><td>Mar 2024</td><td>K21,300</td><td>108</td><td>-5%</td></tr>
                    <tr><td>Apr 2024</td><td>K24,800</td><td>119</td><td>+16%</td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section id="inventory" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Inventory health</p>
                    <h2>Inventory management</h2>
                </div>
                <p class="section-copy">Use this view to spot low stock, healthy stock, and the items worth promoting next.</p>
            </div>
            <div class="inventory-grid">
                <article class="inventory-item">
                    <h4>Mixed Citrus Box</h4>
                    <p>Stock: 5 <span class="low-stock">Low</span></p>
                </article>
                <article class="inventory-item">
                    <h4>Market Pantry Pack</h4>
                    <p>Stock: 18 <span class="stock-ok">Healthy</span></p>
                </article>
                <article class="inventory-item">
                    <h4>Weekend Produce Basket</h4>
                    <p>Stock: 9 <span class="stock-watch">Watch</span></p>
                </article>
                <article class="inventory-item">
                    <h4>Fresh Greens Crate</h4>
                    <p>Stock: 21 <span class="stock-ok">Healthy</span></p>
                </article>
            </div>
        </div>
    </section>

    <section id="reports" class="dashboard-section">
        <div class="stack-grid">
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Finance snapshots</p>
                        <h2>Reports</h2>
                    </div>
                </div>
                <div class="report-preview">
                    <div class="report-item">
                        <span>Monthly sales report</span>
                        <strong>Ready</strong>
                    </div>
                    <div class="report-item">
                        <span>Payout summary</span>
                        <strong>Pending review</strong>
                    </div>
                    <div class="report-item">
                        <span>Refund reconciliation</span>
                        <strong>Updated today</strong>
                    </div>
                </div>
            </article>
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Focus areas</p>
                        <h2>What to review next</h2>
                    </div>
                </div>
                <ul class="info-list">
                    <li>Confirm payout timing for the strongest-performing listings.</li>
                    <li>Match refund trends with repeat support requests.</li>
                    <li>Check whether shipping fees need a seasonal update.</li>
                </ul>
            </article>
        </div>
    </section>

    <section id="promotions" class="dashboard-section">
        <div class="stack-grid">
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Discount management</p>
                        <h2>Promotions</h2>
                    </div>
                    <p class="section-copy">Create coupon codes, toggle them live, and keep a clean view of how buyers will see promotions at checkout.</p>
                </div>

                <form class="promotion-form" id="sellerPromotionForm">
                    <label>
                        <span>Code</span>
                        <input id="sellerPromotionCode" name="code" type="text" maxlength="32" placeholder="WELCOME10" required>
                    </label>
                    <label>
                        <span>Title</span>
                        <input id="sellerPromotionTitle" name="title" type="text" maxlength="80" placeholder="Launch offer" required>
                    </label>
                    <label>
                        <span>Type</span>
                        <select id="sellerPromotionType" name="discountType">
                            <option value="percentage">percentage</option>
                            <option value="fixed">fixed</option>
                            <option value="free_shipping">free shipping</option>
                        </select>
                    </label>
                    <label>
                        <span>Amount</span>
                        <input id="sellerPromotionAmount" name="amount" type="number" min="0" step="0.01" placeholder="10" required>
                    </label>
                    <label>
                        <span>Minimum order</span>
                        <input id="sellerPromotionMinimum" name="minOrderAmount" type="number" min="0" step="0.01" placeholder="0">
                    </label>
                    <label>
                        <span>Max uses</span>
                        <input id="sellerPromotionMaxUses" name="maxUses" type="number" min="1" step="1" placeholder="Optional">
                    </label>
                    <label>
                        <span>Starts at</span>
                        <input id="sellerPromotionStartsAt" name="startsAt" type="datetime-local">
                    </label>
                    <label>
                        <span>Ends at</span>
                        <input id="sellerPromotionEndsAt" name="endsAt" type="datetime-local">
                    </label>
                    <label class="promotion-form__checkbox">
                        <input id="sellerPromotionActive" name="active" type="checkbox" checked>
                        <span>Active immediately</span>
                    </label>
                    <button class="header-action-link header-action-link--primary" type="submit" id="sellerPromotionSubmit">Create promotion</button>
                </form>
            </article>

            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Live codes</p>
                        <h2>Promotion list</h2>
                    </div>
                </div>
                <div class="promotion-list" id="sellerPromotionList">
                    <p class="card-copy">Loading promotions...</p>
                </div>
            </article>
        </div>
    </section>

    <section id="inventory-summary" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Stock snapshot</p>
                    <h2>Inventory summary</h2>
                </div>
            </div>
            <div class="cards-grid summary-grid">
                <article class="card">
                    <h3>Healthy listings</h3>
                    <p class="metric">34</p>
                    <p class="card-copy">Listings with stock above reorder threshold.</p>
                </article>
                <article class="card">
                    <h3>Low stock</h3>
                    <p class="metric">12</p>
                    <p class="card-copy">Listings that need replenishment or a temporary pause.</p>
                </article>
                <article class="card">
                    <h3>Out of stock</h3>
                    <p class="metric">2</p>
                    <p class="card-copy">Items hidden from discovery until restocked.</p>
                </article>
            </div>
        </div>
    </section>

    <section id="transactions" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Payments and payouts</p>
                    <h2>Recent transactions</h2>
                </div>
            </div>
            <table class="data-table">
                <thead>
                    <tr><th>Date</th><th>Description</th><th>Amount</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>2026-03-01</td><td>Sale #123</td><td>K150</td><td><span class="status completed">Completed</span></td></tr>
                    <tr><td>2026-03-02</td><td>Payout transfer</td><td>K2,340</td><td><span class="status processing">Processing</span></td></tr>
                    <tr><td>2026-03-03</td><td>Refund #992</td><td>K45</td><td><span class="status review">Review</span></td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section id="support" class="dashboard-section">
        <div class="stack-grid">
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Support load</p>
                        <h2>Active issues</h2>
                    </div>
                </div>
                <div class="support-grid">
                    <article class="support-card">
                        <strong>Delivery delay follow-up</strong>
                        <p>4 buyers are waiting on a same-day delivery update.</p>
                    </article>
                    <article class="support-card">
                        <strong>Refund clarification</strong>
                        <p>2 orders need a clearer refund status message.</p>
                    </article>
                    <article class="support-card">
                        <strong>Product substitution request</strong>
                        <p>One produce box needs approval for a stock swap.</p>
                    </article>
                </div>
            </article>
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Service quality</p>
                        <h2>Response goals</h2>
                    </div>
                </div>
                <ul class="info-list">
                    <li>First response target: under 2 hours.</li>
                    <li>Refund resolution target: same business day.</li>
                    <li>Escalations should move to priority review when the order value is above K250.</li>
                </ul>
            </article>
        </div>
    </section>

    <section id="tickets" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Resolved and open cases</p>
                    <h2>Ticket history</h2>
                </div>
            </div>
            <table class="data-table">
                <thead>
                    <tr><th>Ticket</th><th>Topic</th><th>Owner</th><th>Status</th></tr>
                </thead>
                <tbody>
                    <tr><td>#1842</td><td>Late delivery</td><td>Support queue</td><td><span class="status completed">Closed</span></td></tr>
                    <tr><td>#1848</td><td>Refund request</td><td>Harmony</td><td><span class="status processing">In progress</span></td></tr>
                    <tr><td>#1851</td><td>Wrong item received</td><td>Store lead</td><td><span class="status review">Needs review</span></td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section id="customers" class="dashboard-section">
        <div class="stack-grid">
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Customer signals</p>
                        <h2>Customer list</h2>
                    </div>
                </div>
                <div class="customer-list">
                    <div class="customer-row">
                        <strong>Maria L.</strong>
                        <span>Repeat buyer - 12 orders</span>
                    </div>
                    <div class="customer-row">
                        <strong>Jason T.</strong>
                        <span>High-value pantry orders</span>
                    </div>
                    <div class="customer-row">
                        <strong>Anna K.</strong>
                        <span>Recently left positive product feedback</span>
                    </div>
                </div>
            </article>
            <article class="surface-card">
                <div class="section-intro">
                    <div>
                        <p class="eyebrow">Retention</p>
                        <h2>Buyer opportunities</h2>
                    </div>
                </div>
                <ul class="info-list">
                    <li>Offer citrus bundle reminders to repeat weekend buyers.</li>
                    <li>Highlight ready-for-pickup listings to local buyers first.</li>
                    <li>Follow up on customers who purchased twice but never followed the stall.</li>
                </ul>
            </article>
        </div>
    </section>

    <section id="settings" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Store readiness</p>
                    <h2>Edit store info</h2>
                </div>
            </div>
            <div class="settings-grid">
                <div class="setting-item">
                    <span>Store identity</span>
                    <strong>Ready</strong>
                </div>
                <div class="setting-item">
                    <span>Shipping profile</span>
                    <strong>Review</strong>
                </div>
                <div class="setting-item">
                    <span>Payout details</span>
                    <strong>Verified</strong>
                </div>
                <div class="setting-item">
                    <span>Support email</span>
                    <strong>Configured</strong>
                </div>
            </div>
        </div>
    </section>

    <section id="staff" class="dashboard-section">
        <div class="surface-card">
            <div class="section-intro">
                <div>
                    <p class="eyebrow">Access control</p>
                    <h2>Manage staff</h2>
                </div>
            </div>
            <div class="team-list">
                <div class="team-card">
                    <strong>Harmony</strong>
                    <span>Owner access</span>
                </div>
                <div class="team-card">
                    <strong>Store assistant</strong>
                    <span>Inventory and support</span>
                </div>
                <div class="team-card">
                    <strong>Finance reviewer</strong>
                    <span>Reports and payout checks</span>
                </div>
            </div>
        </div>
    </section>
</main>
