        <div class="sidebar-section">
            <h3><i class="fas fa-users"></i> Support</h3>
            <ul>
                <li><button class="nav-btn" data-section="support" type="button"><i class="fas fa-headset"></i> Active issues</button></li>
                <li><button class="nav-btn" data-section="tickets" type="button"><i class="fas fa-ticket"></i> Ticket history</button></li>
                <li><button class="nav-btn" data-section="customers" type="button"><i class="fas fa-user-group"></i> Customer signals</button></li>
