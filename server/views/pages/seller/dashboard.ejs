        <div class="sidebar-section">
            <h3><i class="fas fa-sliders"></i> Operations</h3>
            <ul>
                <li><button class="nav-btn" data-section="settings" data-route="/seller/store/settings" type="button"><i class="fas fa-store"></i> Store settings</button></li>
