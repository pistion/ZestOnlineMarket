<%
  const bodyAttrs = page.bodyAttrs || {};
  const isPublicStore = bodyAttrs["public-store"] === "1";
  const viewer = typeof currentUser !== "undefined" ? currentUser : null;
  const viewerRole = viewer && viewer.role ? String(viewer.role).trim().toLowerCase() : "";
  const isBuyerViewer = isPublicStore && viewerRole === "buyer";
  const isGuestViewer = isPublicStore && !viewerRole;
  const paths = {
    marketplace: bodyAttrs["marketplace-path"] || "/marketplace",
    globalFeed: bodyAttrs["global-feed-path"] || "/feed",
    cart: bodyAttrs["checkout-path"] || "/buyer/cart",
    settings: bodyAttrs["seller-settings-path"] || "/seller/store/settings",
    dashboard: bodyAttrs["seller-dashboard-path"] || "/seller/dashboard",
    templateManager: bodyAttrs["seller-template-manager-path"] || "/seller/store/template",
    products: bodyAttrs["seller-products-path"] || "/seller/templates/products",
    store: bodyAttrs["store-path"] || "/marketplace",
    signIn: bodyAttrs["signin-path"] || "/auth/signin?role=buyer",
    orders: "/buyer/purchases",
  };
%>

<div class="academy-storefront">
  <header class="academy-topbar">
    <div class="academy-topbar__inner">
      <div class="academy-branding">
        <a class="academy-brand" id="academyStoreBrand" href="<%= paths.store %>">
          <span class="academy-brand__mark" aria-hidden="true"></span>
          <span id="academyStoreBrandLabel">Classes Studio</span>
        </a>
        <p class="academy-branding__caption">Teaching-led storefront workspace</p>
      </div>

      <div class="academy-topbar__actions">
        <button
          class="academy-nav-toggle"
          type="button"
          data-nav-toggle
          aria-expanded="false"
          aria-controls="academy-storefront-nav"
          aria-label="Toggle store navigation"
        >
          <i class="fa-solid fa-bars"></i>
          <span>Menu</span>
        </button>

        <nav class="academy-nav" id="academy-storefront-nav" data-nav aria-label="Classes store navigation">
          <a href="<%= paths.globalFeed %>" data-page="global-feed">
            <i class="fa-solid fa-earth-africa"></i>
            <span>Global Feed</span>
          </a>
          <a href="<%= paths.marketplace %>" data-page="marketplace">
            <i class="fa-solid fa-compass"></i>
            <span>Marketplace</span>
          </a>

          <% if (isPublicStore) { %>
            <% if (isBuyerViewer) { %>
              <a href="<%= paths.orders %>">
                <i class="fa-solid fa-bag-shopping"></i>
                <span>Orders</span>
              </a>
              <a href="<%= paths.cart %>" data-page="cart">
                <i class="fa-solid fa-cart-shopping"></i>
                <span>Cart</span>
              </a>
            <% } else { %>
              <a href="<%= paths.signIn %>">
                <i class="fa-solid fa-right-to-bracket"></i>
                <span>Sign In</span>
              </a>
            <% } %>
          <% } else { %>
            <a href="<%= paths.dashboard %>" data-page="dashboard">
              <i class="fa-solid fa-chart-line"></i>
              <span>Dashboard</span>
            </a>
            <a href="<%= paths.settings %>" data-page="settings">
              <i class="fa-solid fa-sliders"></i>
              <span>Store Settings</span>
            </a>
            <a href="<%= paths.templateManager %>">
              <i class="fa-solid fa-swatchbook"></i>
              <span>Templates</span>
            </a>
          <% } %>
        </nav>
      </div>
    </div>
  </header>

  <main class="academy-shell">
    <section class="academy-hero" id="top">
      <div class="academy-hero__cover" id="academyStoreCover">
        <div class="academy-hero__wash"></div>
      </div>

      <div class="academy-hero__panel">
        <div class="academy-hero__copy">
          <p class="academy-eyebrow">Teaching storefront</p>
          <h1 class="academy-title" id="academyStoreName">Classes Studio</h1>
          <p class="academy-handle" id="academyStoreHandle">@studio</p>
          <p class="academy-tagline" id="academyStoreTagline">
            Programs, workshops, and guided offers presented with calm structure.
          </p>
          <p class="academy-about" id="academyStoreAbout">
            A softer storefront for educators, coaches, and cohort-led selling, while still using the live Zest catalog underneath.
          </p>
          <div class="academy-pills" id="academyStoreMeta"></div>
          <div class="academy-socials" id="academyStoreSocials" hidden></div>
        </div>

        <aside class="academy-profile-card">
          <div class="academy-profile-card__avatar" id="academyStoreAvatar">C</div>
          <div class="academy-profile-card__body">
            <p class="academy-profile-card__eyebrow">Studio overview</p>
            <h2 id="academyGuideName">Guided learning store</h2>
            <p id="academyGuideNote">
              Live cohorts, self-paced resources, and one-off sessions can sit side by side without losing clear buying paths.
            </p>
            <div class="academy-profile-card__stats">
              <article>
                <span>Programs</span>
                <strong id="academyMetricListings">0</strong>
              </article>
              <article>
                <span>Updates</span>
                <strong id="academyMetricUpdates">0</strong>
              </article>
              <article>
                <span>Status</span>
                <strong id="academyMetricStatus">Draft</strong>
              </article>
            </div>

            <div class="academy-profile-card__actions">
              <% if (!isPublicStore) { %>
                <a class="academy-action academy-action--soft" id="academyPreviewStoreBtn" href="<%= paths.store %>">
                  <i class="fa-regular fa-eye"></i>
                  <span>Preview public store</span>
                </a>
                <a class="academy-action" href="<%= paths.products %>">
                  <i class="fa-solid fa-book-open-reader"></i>
                  <span>Manage catalog</span>
                </a>
              <% } else if (isBuyerViewer) { %>
                <button class="academy-action academy-action--soft" id="academyFollowBtn" type="button">
                  <i class="fa-regular fa-heart"></i>
                  <span>Follow</span>
                </button>
                <button class="academy-action academy-action--ghost" id="academyShareBtn" type="button">
                  <i class="fa-solid fa-share-nodes"></i>
                  <span>Share</span>
                </button>
              <% } else if (isGuestViewer) { %>
                <a class="academy-action academy-action--soft" href="<%= paths.signIn %>">
                  <i class="fa-solid fa-right-to-bracket"></i>
                  <span>Sign in to join</span>
                </a>
                <button class="academy-action academy-action--ghost" id="academyShareBtn" type="button">
                  <i class="fa-solid fa-share-nodes"></i>
                  <span>Share</span>
                </button>
              <% } else { %>
                <button class="academy-action academy-action--ghost" id="academyShareBtn" type="button">
                  <i class="fa-solid fa-share-nodes"></i>
                  <span>Share</span>
                </button>
              <% } %>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="academy-section academy-section--spotlight" id="programs">
      <div class="academy-section__head">
        <div>
          <p class="academy-eyebrow">Spotlight</p>
          <h2 class="academy-section__title">Upcoming guided programs and high-context offers</h2>
          <p class="academy-section__copy" id="academyLearningNote">
            Keep live cohorts visible, but leave room for workshops and resources that help new buyers enter the studio gently.
          </p>
        </div>
      </div>

      <div class="academy-spotlight-rail" id="academySpotlightRail"></div>
      <p class="academy-empty" id="academySpotlightEmpty" hidden>No upcoming programs are live yet.</p>
    </section>

    <section class="academy-section academy-section--programs">
      <div class="academy-section__head academy-section__head--stack">
        <div>
          <p class="academy-eyebrow">Program catalog</p>
          <h2 class="academy-section__title">Courses, workshops, sessions, and digital support</h2>
          <p class="academy-section__copy">
            Everything below is powered by the real store catalog, but framed like an intentional teaching studio instead of a generic storefront.
          </p>
        </div>

        <div class="academy-toolbar">
          <div class="academy-filter-row" id="academyFilterRow"></div>
          <label class="academy-search">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <input id="academyProgramSearch" type="search" placeholder="Search by topic, format, or offer">
          </label>
          <label class="academy-sort">
            <span>Sort</span>
            <select id="academyProgramSort">
              <option value="featured">Featured</option>
              <option value="newest">Newest</option>
              <option value="price-low">Price: low to high</option>
              <option value="price-high">Price: high to low</option>
            </select>
          </label>
        </div>
      </div>

      <div class="academy-program-grid" id="academyProgramGrid"></div>
      <p class="academy-empty" id="academyProgramEmpty" hidden>No programs match this view.</p>
    </section>

    <section class="academy-section academy-section--resources" id="resources">
      <div class="academy-section__head">
        <div>
          <p class="academy-eyebrow">Resources</p>
          <h2 class="academy-section__title">Self-paced and support-led offers</h2>
          <p class="academy-section__copy">
            Resource-style listings stay visible for lower-friction entry points even when your hero section is shaped around live teaching.
          </p>
        </div>
      </div>

      <div class="academy-resource-grid" id="academyResourceGrid"></div>
      <p class="academy-empty" id="academyResourceEmpty" hidden>No resources are live yet.</p>
    </section>

    <section class="academy-section" id="updates">
      <div class="academy-section__head">
        <div>
          <p class="academy-eyebrow">Studio journal</p>
          <h2 class="academy-section__title">Cohort openings, reminders, and teaching notes</h2>
          <p class="academy-section__copy">
            The update feed keeps the storefront warm and current without breaking the shared Zest runtime underneath.
          </p>
        </div>
      </div>

      <div class="academy-update-grid" id="academyUpdatesList"></div>
      <p class="academy-empty" id="academyUpdatesEmpty" hidden>No teaching updates posted yet.</p>
    </section>

    <section class="academy-section academy-section--faq" id="faq">
      <div class="academy-section__head">
        <div>
          <p class="academy-eyebrow">FAQ</p>
          <h2 class="academy-section__title">Studio flows built around clarity</h2>
        </div>
      </div>

      <div class="academy-faq">
        <article class="academy-faq__item">
          <button class="academy-faq__question" type="button">
            <span>Can this handle both live cohorts and self-paced programs?</span>
            <i class="fa-solid fa-plus"></i>
          </button>
          <div class="academy-faq__answer">
            <p>Yes. The storefront can present workshop-style, cohort-style, and digital resource offers side by side.</p>
          </div>
        </article>

        <article class="academy-faq__item">
          <button class="academy-faq__question" type="button">
            <span>Do buyers still use the same listing and checkout flow?</span>
            <i class="fa-solid fa-plus"></i>
          </button>
          <div class="academy-faq__answer">
            <p>Yes. Even with teaching-led copy, the actual product and checkout routes stay canonical.</p>
          </div>
        </article>

        <article class="academy-faq__item">
          <button class="academy-faq__question" type="button">
            <span>Can seller preview stay clean while editing the real catalog?</span>
            <i class="fa-solid fa-plus"></i>
          </button>
          <div class="academy-faq__answer">
            <p>Yes. Seller mode keeps preview and management links nearby without leaking them into the public storefront.</p>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer class="academy-footer">
    <div class="academy-footer__inner">
      <div>
        <strong>Classes Studio</strong>
        <p>Structured storefronts for programs, workshops, and guided learning on Zest.</p>
      </div>
      <div class="academy-footer__links">
        <a href="<%= paths.marketplace %>">Marketplace</a>
        <a href="<%= paths.globalFeed %>">Global Feed</a>
      </div>
    </div>
  </footer>
</div>
