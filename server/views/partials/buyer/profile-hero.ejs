<section class="profile-hero">
  <div class="cover-image" id="buyerHeroCover">
    <div class="avatar" id="buyerHeroAvatar" aria-label="Profile avatar">B</div>

    <div class="hero-overlay">
      <div class="hero-pills" aria-label="Buyer profile details">
        <span class="pill" id="buyerHeroBuyerPill"><i class="fa-solid fa-user"></i> Buyer account</span>
        <span class="pill" id="buyerHeroStatusPill"><i class="fa-solid fa-sparkles"></i> Buyer pulse warming up</span>
        <a class="pill" id="buyerHeroEmail" href="mailto:hello@zest.market"><i class="fa-solid fa-envelope"></i> hello@zest.market</a>
        <a class="pill" href="/buyer/feed"><i class="fa-solid fa-rss"></i> Personalized feed</a>
        <a class="pill" href="/buyer/purchases"><i class="fa-solid fa-bag-shopping"></i> Orders</a>
        <a class="pill" href="/buyer/settings"><i class="fa-solid fa-sliders"></i> Settings</a>
        <a class="pill" href="/feed"><i class="fa-solid fa-globe"></i> Global feed</a>
      </div>
    </div>
  </div>

  <div class="profile-info">
    <div class="profile-head">
      <div class="profile-title">
        <h1 class="profile-name" id="buyerHeroName">Buyer Profile</h1>
        <p class="profile-handle" id="buyerHeroHandle">@buyer</p>
      </div>

      <div class="profile-social" aria-label="Quick links">
        <a class="icon-btn" href="/marketplace" aria-label="Marketplace"><i class="fa-solid fa-store"></i></a>
        <a class="icon-btn" href="/buyer/feed" aria-label="Personalized Feed"><i class="fa-solid fa-rss"></i></a>
        <a class="icon-btn" href="/buyer/purchases" aria-label="Orders"><i class="fa-solid fa-bag-shopping"></i></a>
        <a class="icon-btn" href="/buyer/settings" aria-label="Settings"><i class="fa-solid fa-sliders"></i></a>
        <a class="icon-btn" href="/feed" aria-label="Global Feed"><i class="fa-solid fa-globe"></i></a>
        <a class="icon-btn" href="#buyerWishlistSection" aria-label="Wishlist"><i class="fa-solid fa-heart"></i></a>
        <a class="share-btn" id="buyerShareProfile" href="/marketplace"><i class="fa-solid fa-share-nodes"></i> Share</a>
        <button class="share-btn" id="buyerSwitchAccountBtn" type="button">
          <i class="fa-solid fa-right-left"></i> Switch Account
        </button>
        <button class="share-btn share-btn--primary" id="buyerSignOutBtn" type="button">
          <i class="fa-solid fa-sign-out-alt"></i> Sign Out
        </button>
      </div>
    </div>

    <p class="profile-bio" id="buyerHeroBio">
      Keep your marketplace activity, followed stores, saved items, and recent shopping signals in one buyer-focused profile.
    </p>

    <div class="profile-stats">
      <div class="stat">
        <div class="stat-number" id="buyerPurchasesStat">0</div>
        <div class="stat-label">Purchases</div>
      </div>
      <div class="stat">
        <div class="stat-number" id="buyerWishlistStat">0</div>
        <div class="stat-label">Wishlist</div>
      </div>
      <div class="stat">
        <div class="stat-number" id="buyerFollowingStat">0</div>
        <div class="stat-label">Following</div>
      </div>
      <div class="stat">
        <div class="stat-number" id="buyerSavedStoresStat">0</div>
        <div class="stat-label">Saved Stores</div>
      </div>
    </div>
  </div>
</section>
