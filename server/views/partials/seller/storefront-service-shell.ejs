          answer:
            "Yes. Use store updates for availability windows, recent work, mini-session drops, and linked featured packages.",
        },
      ],
      listingLabel: "Session",
    },
    programmer: {
      brand: "Developer Profile",
      kicker: "Services and builds",
      heroTitle: "A clean delivery-focused storefront for coding services, retainers, and shipped digital work.",
      heroCopy:
        "Present your services like a polished studio page while keeping the real listing, checkout, and update flows fully connected.",
