    },
  };
  const template = templateConfigs[templateKey] || templateConfigs.art;
%>

<div class="service-storefront">
  <header class="service-topbar">
    <div class="service-topbar__inner">
      <a class="service-brand" id="serviceStoreBrand" href="<%= paths.store %>">
        <span class="service-brand__mark" aria-hidden="true"></span>
        <span id="serviceStoreBrandLabel"><%= template.brand %></span>
      </a>

      <button
        class="service-chip service-nav-toggle"
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-controls="service-storefront-nav"
        aria-label="Toggle navigation"
      >
        <i class="fa-solid fa-bars"></i>
        <span>Menu</span>
      </button>

      <nav class="service-nav" id="service-storefront-nav" data-nav aria-label="Store navigation">
        <a href="<%= paths.globalFeed %>" data-page="global-feed">
          <i class="fa-solid fa-earth-americas"></i>
          <span>Global Feed</span>
        </a>
        <a href="<%= paths.marketplace %>" data-page="marketplace">
          <i class="fa-solid fa-compass"></i>
          <span>Marketplace</span>
        </a>
        <% if (isPublicStore) { %>
          <a href="<%= paths.cart %>" data-page="cart">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>Cart</span>
          </a>
        <% } else { %>
          <a href="<%= paths.settings %>" data-page="settings">
            <i class="fa-solid fa-store"></i>
            <span>Store Settings</span>
          </a>
          <a href="<%= paths.dashboard %>" data-page="dashboard">
            <i class="fa-solid fa-chart-line"></i>
            <span>Dashboard</span>
          </a>
          <a href="<%= paths.products %>">
            <i class="fa-solid fa-boxes-stacked"></i>
            <span>Manage Catalog</span>
          </a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="service-shell">
    <section class="service-hero">
      <div class="service-hero__cover" id="serviceStoreCover">
        <div class="service-hero__cover-wash"></div>
      </div>

      <div class="service-hero__panel">
        <div class="service-hero__identity">
          <div class="service-hero__avatar" id="serviceStoreAvatar">S</div>

          <div class="service-hero__copy">
            <p class="service-hero__kicker"><%= template.kicker %></p>
            <h1 class="service-hero__title" id="serviceStoreName"><%= template.brand %></h1>
            <p class="service-hero__handle" id="serviceStoreHandle">@store</p>
            <p class="service-hero__tagline" id="serviceStoreTagline"><%= template.heroTitle %></p>
            <p class="service-hero__about" id="serviceStoreAbout"><%= template.heroCopy %></p>
            <div class="service-hero__meta" id="serviceStoreMetaPills"></div>
          </div>
        </div>

        <div class="service-hero__actions">
          <% if (isPublicStore) { %>
            <button class="service-btn service-btn--secondary" id="serviceFollowBtn" type="button">
              <i class="fa-regular fa-heart"></i>
              <span>Follow</span>
            </button>
            <button class="service-btn service-btn--ghost" id="serviceShareBtn" type="button">
              <i class="fa-solid fa-share-nodes"></i>
              <span>Share</span>
            </button>
            <a class="service-btn" id="serviceOpenCartLink" href="<%= paths.cart %>">
              <i class="fa-solid fa-cart-shopping"></i>
              <span>Open cart</span>
            </a>
          <% } else { %>
            <a class="service-btn service-btn--secondary" id="servicePreviewStoreBtn" href="<%= paths.store %>">
              <i class="fa-regular fa-eye"></i>
              <span>Preview public store</span>
            </a>
            <a class="service-btn service-btn--ghost" href="<%= paths.settings %>">
              <i class="fa-solid fa-sliders"></i>
              <span>Store settings</span>
            </a>
            <a class="service-btn" href="<%= paths.products %>">
              <i class="fa-solid fa-boxes-stacked"></i>
              <span>Manage listings</span>
            </a>
          <% } %>
        </div>
      </div>

      <div class="service-hero__socials" id="serviceStoreSocials" hidden></div>

      <nav class="service-section-nav" aria-label="Store sections">
        <a href="#overview">Overview</a>
        <a href="#updates">Updates</a>
        <a href="#catalog">Catalog</a>
        <a href="#highlights">Highlights</a>
        <a href="#faq">FAQ</a>
      </nav>
    </section>

    <section class="service-overview" id="overview">
      <div class="service-section-head">
        <div>
          <p class="service-section-kicker">Store overview</p>
          <h2 class="service-section-title"><%= template.heroTitle %></h2>
          <p class="service-section-copy"><%= template.heroCopy %></p>
        </div>
      </div>

      <div class="service-overview__grid">
        <% template.overviewCards.forEach((card) => { %>
          <article class="service-info-card">
            <h3><%= card.title %></h3>
            <p><%= card.copy %></p>
          </article>
        <% }); %>
      </div>

      <div class="service-metric-grid">
        <article class="service-metric-card">
          <span class="service-metric-card__label">Live listings</span>
          <strong class="service-metric-card__value" id="serviceMetricListings">0</strong>
        </article>
        <article class="service-metric-card">
          <span class="service-metric-card__label">Store updates</span>
          <strong class="service-metric-card__value" id="serviceMetricUpdates">0</strong>
        </article>
        <article class="service-metric-card">
          <span class="service-metric-card__label">Store status</span>
          <strong class="service-metric-card__value" id="serviceMetricStatus">Draft</strong>
        </article>
      </div>
    </section>

    <section class="service-updates" id="updates">
      <div class="service-section-head">
        <div>
          <p class="service-section-kicker"><%= template.updatesKicker %></p>
          <h2 class="service-section-title"><%= template.updatesTitle %></h2>
          <p class="service-section-copy"><%= template.updatesCopy %></p>
        </div>

        <% if (!isPublicStore) { %>
          <div class="service-section-actions">
            <a class="service-chip" href="<%= paths.products %>#updatesSection">
              <i class="fa-solid fa-bullhorn"></i>
              <span>Manage updates</span>
            </a>
          </div>
        <% } %>
      </div>

      <div class="service-updates__list" id="serviceUpdatesList" role="feed" aria-live="polite"></div>

      <div class="service-empty-state" id="serviceUpdatesEmpty" hidden>
        <div class="service-empty-state__icon">
          <i class="fa-solid fa-bullhorn"></i>
        </div>
        <h3>No updates yet</h3>
        <p>The live store feed has not published an update here yet.</p>
      </div>
    </section>

    <section class="service-catalog" id="catalog">
      <div class="service-section-head">
        <div>
          <p class="service-section-kicker"><%= template.catalogKicker %></p>
          <h2 class="service-section-title"><%= template.catalogTitle %></h2>
          <p class="service-section-copy"><%= template.catalogCopy %></p>
        </div>

        <div class="service-section-actions">
          <% if (isPublicStore) { %>
            <a class="service-chip" href="<%= paths.marketplace %>">
              <i class="fa-solid fa-compass"></i>
              <span>Back to marketplace</span>
            </a>
          <% } else { %>
            <a class="service-chip" href="<%= paths.products %>">
              <i class="fa-solid fa-pen-ruler"></i>
              <span>Open products workspace</span>
            </a>
          <% } %>
        </div>
      </div>

      <div class="service-featured-rail" id="serviceFeaturedRail"></div>
      <div class="service-products-grid" id="serviceProductsGrid"></div>

      <div class="service-empty-state" id="serviceProductsEmpty" hidden>
        <div class="service-empty-state__icon">
          <i class="fa-solid fa-box-open"></i>
        </div>
        <h3>No live <%= template.listingLabel.toLowerCase() %> listings yet</h3>
        <p>
          <% if (isPublicStore) { %>
            This store has not published any public listings yet.
          <% } else { %>
            Add listings from the products workspace and they will appear here automatically.
          <% } %>
        </p>
      </div>
    </section>

    <section class="service-highlights" id="highlights">
      <div class="service-section-head">
        <div>
          <p class="service-section-kicker">Template highlights</p>
          <h2 class="service-section-title"><%= template.highlightsTitle %></h2>
        </div>
      </div>

      <div class="service-highlights__grid">
        <% template.highlights.forEach((copy) => { %>
          <article class="service-highlight-card">
            <div class="service-highlight-card__icon">
              <i class="fa-solid fa-sparkles"></i>
            </div>
            <p><%= copy %></p>
          </article>
        <% }); %>
      </div>
    </section>

    <section class="service-faq" id="faq">
      <div class="service-section-head">
        <div>
          <p class="service-section-kicker">FAQ</p>
          <h2 class="service-section-title">Common questions</h2>
        </div>
      </div>

      <div class="service-faq__list">
        <% template.faq.forEach((item) => { %>
          <article class="service-faq__item">
            <button class="service-faq__question" type="button">
              <span><%= item.question %></span>
              <i class="fa-solid fa-plus"></i>
            </button>
            <div class="service-faq__answer">
              <p><%= item.answer %></p>
            </div>
          </article>
        <% }); %>
      </div>
    </section>
  </main>

  <footer class="service-footer">
    <div class="service-footer__inner">
      <p>&copy; 2026 Zest Marketplace. Storefront templates run on the live catalog and feed system.</p>
      <div class="service-footer__links">
        <a href="<%= paths.marketplace %>">Marketplace</a>
        <a href="<%= paths.globalFeed %>">Global Feed</a>
        <% if (!isPublicStore) { %>
          <a href="<%= paths.dashboard %>">Dashboard</a>
        <% } %>
      </div>
    </div>
  </footer>
</div>
