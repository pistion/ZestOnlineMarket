<%
  const templateKey =
    (page.bodyAttrs && page.bodyAttrs["store-template-key"]) || storefrontTemplate || "art";
  const isPublicStore = page.bodyAttrs && page.bodyAttrs["public-store"] === "1";
  const paths = {
    marketplace: (page.bodyAttrs && page.bodyAttrs["marketplace-path"]) || "/marketplace",
    globalFeed: (page.bodyAttrs && page.bodyAttrs["global-feed-path"]) || "/feed",
    cart: (page.bodyAttrs && page.bodyAttrs["checkout-path"]) || "/buyer/cart",
    settings: (page.bodyAttrs && page.bodyAttrs["seller-settings-path"]) || "/seller/store/settings",
    dashboard: (page.bodyAttrs && page.bodyAttrs["seller-dashboard-path"]) || "/seller/dashboard",
    templateManager:
      (page.bodyAttrs && page.bodyAttrs["seller-template-manager-path"]) || "/seller/store/template",
