      catalogKicker: "Service catalog",
      catalogTitle: "Live development listings",
      catalogCopy:
        "Every service card here now comes from the same production catalog engine as the products storefront, just framed for developer work.",
      highlightsTitle: "What this developer template now does well",
      highlights: [
        "Live services replace older static portfolio cards and off-template cart behavior.",
        "Seller mode routes back into the products workspace for full catalog management instead of duplicating fragile controls.",
        "Public buyers get a coherent service storefront with working listing and cart actions.",
      ],
      faq: [
        {
          question: "Can this template handle retainers and one-off projects?",
          answer:
            "Yes. Listings can represent scoped projects, retainers, audits, code reviews, and packaged delivery work.",
        },
        {
          question: "Does it still feel like a developer profile?",
          answer:
            "Yes. The language and presentation stay service-oriented while the underlying logic stays aligned with the live catalog engine.",
        },
        {
          question: "Where do sellers manage the real listings?",
          answer:
            "Seller preview mode points straight to the products workspace, which remains the canonical catalog management surface.",
        },
      ],
      listingLabel: "Service",
    },
    music: {
      brand: "Music Studio",
      kicker: "Releases and music offers",
      heroTitle: "A release-led storefront for tracks, lessons, beats, licensing, and artist updates.",
      heroCopy:
        "Keep the music personality of the template while making the cards, updates, and catalog actions run on the same dependable live store system.",
      overviewCards: [
        {
          title: "Release-first framing",
          copy: "Singles, albums, lessons, and production offers can all live in one store without splitting into disconnected template logic.",
        },
        {
