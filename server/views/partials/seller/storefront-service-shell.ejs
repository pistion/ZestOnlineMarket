    },
    photography: {
      brand: "Photography Studio",
      kicker: "Sessions and visual work",
      heroTitle: "A visual-first storefront for shoots, packages, edits, and portfolio-led selling.",
      heroCopy:
        "Use one live store to present shoot packages, event coverage, edits, and featured sessions while keeping the same Zest buying flow.",
      overviewCards: [
        {
          title: "Portfolio-led layout",
          copy: "Showcase your strongest visuals first, then let buyers move naturally into the real package listing.",
        },
        {
          title: "Session-ready offers",
          copy: "Use listings for portrait shoots, event coverage, retainer packages, and add-ons without fake placeholder cards.",
        },
        {
          title: "Clear booking context",
          copy: "Location notes, delivery details, and package structure stay readable instead of buried in demo copy.",
        },
      ],
      updatesKicker: "Shoot updates",
      updatesTitle: "Recent shoots, edits, and announcements",
      updatesCopy:
        "Publish quick updates about bookings, edits, event coverage, or seasonal packages and keep the storefront feeling active.",
      catalogKicker: "Packages and offers",
      catalogTitle: "Live photography listings",
      catalogCopy:
        "This section now runs on the same real catalog layer as the products template, so public and seller views stay aligned.",
      highlightsTitle: "What this photography template emphasizes",
      highlights: [
        "Packages, add-ons, and featured sessions render from real store data instead of static demo pricing.",
        "Update cards support visual storytelling while still linking buyers into the real listing path.",
        "Public storefronts stay clean while seller mode keeps management routes one click away.",
      ],
      faq: [
        {
          question: "Can I use this for packages and one-off shoots?",
          answer:
            "Yes. Listings can represent event packages, portrait sessions, commercial shoots, and photography add-ons.",
        },
        {
